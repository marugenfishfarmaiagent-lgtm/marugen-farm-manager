# Frontend (Vite) — copy to .env for local dev; set the same keys in Vercel → Environment Variables (Production).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — production error tracking (Phase 2). Leave unset to disable Sentry.
# VITE_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000

# Do NOT set VITE_GEMINI_API_KEY — Gemini key lives in Supabase Edge Function secrets only.

# Web Push (PWA phone notifications) — run: bash scripts/generate-vapid-keys.sh
# VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@your-farm.com

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
# GEMINI_API_KEY=your-gemini-api-key
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT (same as above; private key server-only)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (auto-injected on Supabase hosted functions)
